CcoCampaignMission
{
	ExHasScriptedTimer
	{
		MissionDefinitionContext.PrimaryObjectivesList.Filter(ScriptKey.IsEmpty == false && ScriptKey.Contains("timer")).IsEmpty == false
	}

	ExGetScriptedTimer
	{
		MissionDefinitionContext.PrimaryObjectivesList.Filter(ScriptKey.IsEmpty == false && ScriptKey.Contains("timer")).FirstContext
	}
}